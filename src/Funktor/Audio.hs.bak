module Funktor.Audio
    ( openDevice
    , closeDevice
    , noteOn
    , noteOff
    ) where

import qualified SDL
import qualified Data.Vector.Storable.Mutable as VM
import Control.Monad (forM_)
import Control.Concurrent.STM (TVar, newTVarIO, atomically, readTVarIO, modifyTVar')
import Data.Int (Int8, Int16, Int32)
import Data.Word (Word8, Word16)
import Funktor.Core.Types (Pitch, Velocity, midiToFreq)
import Funktor.Audio.State (bufferSize, sampleRate, AudioState, OscState, createAudioState)
import Funktor.Audio.Sine (sineCallback, createSineAudioState)

openDevice :: IO (SDL.AudioDevice, TVar AudioState)
openDevice = do
    SDL.initialize [SDL.InitAudio]
    stateVar <- newTVarIO (createSineAudioState 440.0 0.3) -- Default to A4 note (440Hz) with 30% amplitude
    (dev, _) <- SDL.openAudioDevice SDL.OpenDeviceSpec
        { SDL.openDeviceFreq     = SDL.Mandate 44100
        , SDL.openDeviceFormat   = SDL.Mandate SDL.FloatingLEAudio
        , SDL.openDeviceChannels = SDL.Mandate SDL.Mono
        , SDL.openDeviceSamples  = 512
        , SDL.openDeviceUsage    = SDL.ForPlayback
        , SDL.openDeviceName     = Nothing
        , SDL.openDeviceCallback = sineCallback stateVar
        }
    SDL.setAudioDevicePlaybackState dev SDL.Play
    pure (dev, stateVar)

closeDevice :: SDL.AudioDevice -> IO ()
closeDevice = SDL.closeAudioDevice

noteOn :: TVar AudioState -> Pitch -> Velocity -> IO ()
noteOn stateVar pitch velocity = do
    let frequency = midiToFreq pitch
        amplitude = fromRational (unVelocity velocity) * 0.3 -- Scale velocity to 30% max
    atomically $ modifyTVar' stateVar $ \s ->
        s { audioOsc = (audioOsc s) { oscFreq = frequency, oscAmplitude = amplitude } }

noteOff :: TVar AudioState -> Pitch -> IO ()
noteOff _ _ = pure () -- For now, do nothing - in a full implementation we'd handle release
